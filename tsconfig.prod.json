{
    "extends": "@code-essentials/tsconfig/tsconfig.prod.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        // DOM is removed in @code-essentials/tsconfig/tsconfig.prod.json
        "lib": [
            "ESNext",
            "DOM",
        ],
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "src/**/*.spec.ts",
        "test"
    ],
}